{
  "name": "@earendil-works/pi-libp2p-mesh",
  "version": "0.3.0",
  "description": "P2P mesh network extension for pi agents built on libp2p — peer discovery, direct messaging, and gossip broadcast.",
  "keywords": [
    "pi-package",
    "p2p",
    "libp2p",
    "mesh",
    "gossip"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/node.js",
      "types": "./dist/node.d.ts"
    },
    "./protocols": {
      "import": "./dist/protocols.js",
      "types": "./dist/protocols.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/",
    "index.ts",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "npx tsx test-network.mjs",
    "test:rigorous": "npx tsx rigorous-concurrent-test.mjs",
    "test:extension": "npx tsx test-extension.mjs",
    "test:fifo": "node test-fifo-queue.mjs",
    "test:identity": "npx tsx test-identity.mjs",
    "test:leak": "node test-leak.mjs",
    "test:negative": "npx tsx test-negative.mjs",
    "test:all": "npm run test:extension && npm run test:fifo && npm run test:leak && npm run test:identity && npm run test:negative && npm run test",
    "pretest": "npm run build"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "https://raw.githubusercontent.com/libp2p/js-libp2p/main/img/libp2p-logo.png"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/bootstrap": "^12.0.22",
    "@libp2p/crypto": "^5.1.18",
    "@libp2p/identify": "^4.1.6",
    "@libp2p/interface": "^3.2.2",
    "@libp2p/kad-dht": "^16.3.0",
    "@libp2p/mdns": "^12.0.22",
    "@libp2p/peer-id": "^6.0.9",
    "@libp2p/tcp": "^11.0.20",
    "@libp2p/websockets": "^10.1.13",
    "@multiformats/multiaddr": "^13.0.3",
    "libp2p": "^3.3.1",
    "multiformats": "^14.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/earendil-works/pi-libp2p-mesh.git"
  },
  "bugs": {
    "url": "https://github.com/earendil-works/pi-libp2p-mesh/issues"
  },
  "homepage": "https://github.com/earendil-works/pi-libp2p-mesh#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
